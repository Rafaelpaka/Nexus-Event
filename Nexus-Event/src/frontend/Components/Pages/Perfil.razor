@page "/perfil"
@using frontend.Models
@using frontend.Services
@inject AuthService AuthService
@inject UsuarioService UsuarioService
@inject NavigationManager Navigation

@if (!AuthService.EstaLogado)
{
    <div class="empty-state">
        <div class="empty-state-icon">🔒</div>
        <h3>Você precisa estar logado</h3>
        <a href="/login" class="btn btn-primary">Ir para Login</a>
    </div>
    return;
}

<div class="form-page">
    <div class="form-card">
        <h1>👤 Meu Perfil</h1>
        <p class="form-card-subtitle">Atualize suas informações pessoais</p>

        <div class="form-field">
            <label class="form-label">CPF</label>
            <input class="form-input" type="text" value="@AuthService.UsuarioAtual!.Cpf" readonly />
        </div>

        <div class="form-field">
            <label class="form-label">Nome *</label>
            <input class="form-input" type="text" placeholder="Seu nome" @bind="nome" />
        </div>

        <div class="form-field">
            <label class="form-label">Login *</label>
            <input class="form-input" type="text" placeholder="Seu login" @bind="login" />
        </div>

        <div class="form-field">
            <label class="form-label">Email *</label>
            <input class="form-input" type="email" placeholder="seu@email.com" @bind="email" />
        </div>

        <div class="form-field">
            <label class="form-label">Nova Senha <small style="color:#9ca3af;">(deixe em branco para manter)</small></label>
            <input class="form-input" type="password" placeholder="Mín. 8 caracteres" @bind="senha" />
        </div>

        <div class="form-field">
            <label class="form-label">Telefone</label>
            <input class="form-input" type="text" placeholder="(XX) XXXXX-XXXX" @bind="telefone" />
        </div>

        <div class="form-field">
            <label class="form-label">Endereço</label>
            <input class="form-input" type="text" placeholder="Rua, número, bairro" @bind="endereco" />
        </div>

        <button class="btn btn-gold btn-full" @onclick="Salvar" disabled="@salvando">
            @(salvando ? "Salvando..." : "💾 Salvar Alterações")
        </button>

        @if (!string.IsNullOrEmpty(mensagem))
        {
            <div class="alert @(erro ? "alert-error" : "alert-success")">@mensagem</div>
        }
    </div>
</div>

@code {
    private string nome = string.Empty;
    private string login = string.Empty;
    private string email = string.Empty;
    private string senha = string.Empty;
    private string telefone = string.Empty;
    private string endereco = string.Empty;
    private string mensagem = string.Empty;
    private bool erro;
    private bool salvando;

    protected override void OnInitialized()
    {
        if (AuthService.EstaLogado)
        {
            nome = AuthService.UsuarioAtual!.Nome;
            email = AuthService.UsuarioAtual!.Email;
        }
    }

    private async Task Salvar()
    {
        erro = false; mensagem = string.Empty;
        if (string.IsNullOrWhiteSpace(nome) || string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(login))
        { erro = true; mensagem = "Nome, Login e Email são obrigatórios."; return; }

        salvando = true;
        var (sucesso, msg) = await UsuarioService.Atualizar(new AtualizarUsuarioRequest
        {
            Cpf = AuthService.UsuarioAtual!.Cpf,
            Nome = nome, Login = login, Email = email,
            Senha = senha, Telefone = telefone, Endereco = endereco
        });
        mensagem = msg; erro = !sucesso; salvando = false;

        if (sucesso)
        {
            AuthService.UsuarioAtual!.Nome = nome;
            AuthService.UsuarioAtual!.Email = email;
            AuthService.NotificarMudanca();
        }
    }
}
