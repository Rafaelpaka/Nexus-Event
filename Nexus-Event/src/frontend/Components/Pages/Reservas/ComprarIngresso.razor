@page "/comprar/{EventoId:int}"
@using frontend.Models
@using frontend.Services
@inject ReservaService ReservaService
@inject AuthService AuthService
@inject NavigationManager Navigation

<div class="form-page">
    <div class="form-card">
        <h1>🎫 Comprar Ingresso</h1>

        @if (!AuthService.EstaLogado)
        {
            <p class="form-card-subtitle">Você precisa estar logado para comprar</p>
            <a href="/login" class="btn btn-primary btn-full">Fazer Login</a>
        }
        else
        {
            <p style="color:#6b7280; text-align:center;">
                CPF: <strong>@AuthService.UsuarioAtual!.Cpf</strong> &nbsp;|&nbsp;
                Evento: <strong>#@EventoId</strong>
            </p>

            <div class="form-field">
                <label class="form-label">Cupom de desconto (opcional)</label>
                <input class="form-input" type="text" placeholder="Ex: DESC10" @bind="codigoCupom" />
            </div>

            <button class="btn btn-gold btn-full" @onclick="Comprar" disabled="@carregando">
                @(carregando ? "Processando..." : "✅ Confirmar Compra")
            </button>

            @if (!string.IsNullOrEmpty(erro)) { <div class="alert alert-error">⚠️ @erro</div> }
            @if (!string.IsNullOrEmpty(sucesso)) { <div class="alert alert-success">✅ @sucesso</div> }
        }
    </div>
</div>

@code {
    [Parameter] public int EventoId { get; set; }
    private string? codigoCupom;
    private string? erro;
    private string? sucesso;
    private bool carregando;

    private async Task Comprar()
    {
        erro = sucesso = null;
        carregando = true;
        var (ok, mensagem) = await ReservaService.Criar(new CriarReservaRequest
        {
            UsuarioCpf = AuthService.UsuarioAtual!.Cpf,
            EventoId = EventoId,
            CodigoCupom = codigoCupom
        });
        carregando = false;
        if (ok) { sucesso = mensagem; await Task.Delay(2000); Navigation.NavigateTo("/minhas-reservas"); }
        else erro = mensagem;
    }
}
