@page "/minhas-reservas"
@using frontend.Models
@using frontend.Services
@inject ReservaService ReservaService
@inject AuthService AuthService
@inject NavigationManager Navigation

<div class="page-bg">
    <section class="page-header">
        <h1>🎟️ Minhas Reservas</h1>
        <p>Acompanhe seus ingressos comprados</p>
    </section>

    @if (!AuthService.EstaLogado)
    {
        <div class="empty-state">
            <div class="empty-state-icon">🔒</div>
            <h3>Você precisa estar logado</h3>
            <a href="/login" class="btn btn-primary">Fazer Login</a>
        </div>
    }
    else if (reservas is null)
    {
        <div class="loading">Carregando...</div>
    }
    else if (!reservas.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon">🎫</div>
            <h3>Nenhuma reserva ainda</h3>
            <p>Explore nossos eventos e garanta seu ingresso!</p>
            <a href="/eventos" class="btn btn-gold">Ver Eventos</a>
        </div>
    }
    else
    {
        <div class="reservation-list">
            @foreach (var reserva in reservas)
            {
                <div class="reservation-card">
                    <div class="reservation-info">
                        <h3>@reserva.NomeEvento</h3>
                        <p>🎫 @reserva.CodigoReserva</p>
                        @if (!string.IsNullOrEmpty(reserva.CupomUtilizado))
                        {
                            <p>🏷️ Cupom: <strong>@reserva.CupomUtilizado</strong></p>
                        }
                    </div>
                    <div class="reservation-actions">
                        <p class="reservation-price">@reserva.ValorFinalPago.ToString("C")</p>
                        <button class="btn btn-danger" @onclick="() => Cancelar(reserva.Id)">
                            Cancelar
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<ReservaModel>? reservas;

    protected override async Task OnInitializedAsync()
    {
        if (AuthService.EstaLogado)
            reservas = await ReservaService.ListarPorCpf(AuthService.UsuarioAtual!.Cpf);
    }

    private async Task Cancelar(int id)
    {
        var (ok, _) = await ReservaService.Cancelar(id, AuthService.UsuarioAtual!.Cpf);
        if (ok) reservas = await ReservaService.ListarPorCpf(AuthService.UsuarioAtual!.Cpf);
    }
}
