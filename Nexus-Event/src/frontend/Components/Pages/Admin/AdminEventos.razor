@page "/admin/eventos"
@using frontend.Models
@using frontend.Services
@inject EventoService EventoService
@inject AuthService AuthService
@inject NavigationManager Navigation

@if (!AuthService.EhAdmin)
{
    <p>Acesso negado.</p>
}
else
{
    <div class="form-container" style="max-width:500px; margin:2rem auto; padding:2rem;">
        <h1 style="color:#5f0d51; text-align:center;">Cadastrar Evento</h1>

        <div class="form-group">
            <label>Nome do Evento</label>
            <input class="form-control-custom" type="text"
                   placeholder="Nome do evento"
                   @bind="request.Nome" />
        </div>
        <div class="form-group">
            <label>Capacidade Total</label>
            <input class="form-control-custom" type="number"
                   @bind="request.CapacidadeTotal" />
        </div>
        <div class="form-group">
            <label>Data do Evento</label>
            <input class="form-control-custom" type="datetime-local"
                   @bind="request.DataEvento" />
        </div>
        <div class="form-group">
            <label>Preço Padrão</label>
            <input class="form-control-custom" type="number"
                   step="0.01"
                   @bind="request.PrecoPadrao" />
        </div>

        <button type="button" class="auth-main-button"
                @onclick="Cadastrar" disabled="@carregando">
            @(carregando ? "Cadastrando..." : "Cadastrar Evento")
        </button>

        @if (!string.IsNullOrEmpty(erro))
        {
            <div style="background:#fee2e2;border:1px solid #ef4444;border-radius:8px;padding:12px;margin-top:1rem;color:#b91c1c;">
                ⚠️ @erro
            </div>
        }
        @if (!string.IsNullOrEmpty(sucesso))
        {
            <div style="background:#dcfce7;border:1px solid #22c55e;border-radius:8px;padding:12px;margin-top:1rem;color:#15803d;">
                ✅ @sucesso
            </div>
        }
    </div>
}

@code {
    private CriarEventoRequest request = new();
    private string? erro;
    private string? sucesso;
    private bool carregando = false;

    protected override void OnInitialized()
    {
        if (!AuthService.EhAdmin)
            Navigation.NavigateTo("/");
    }

    private async Task Cadastrar()
    {
        erro = null;
        sucesso = null;
        carregando = true;

        var (ok, mensagem) = await EventoService.Cadastrar(request);
        carregando = false;

        if (ok)
        {
            sucesso = mensagem;
            request = new();
        }
        else
        {
            erro = mensagem;
        }
    }
}