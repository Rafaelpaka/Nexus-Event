@page "/admin/eventos"
@using frontend.Models
@using frontend.Services
@inject EventoService EventoService
@inject AuthService AuthService
@inject NavigationManager Navigation

@if (!AuthService.EhAdmin)
{
    <div class="access-denied">⛔ Acesso negado</div>
}
else
{
    <div class="page-bg">
        <section class="page-header">
            <h1>⚙️ Cadastrar Evento</h1>
            <p>Preencha os dados do novo evento</p>
        </section>

        <div class="admin-card" style="margin-top:-1rem;">
            <div class="form-field">
                <label class="form-label">Nome do Evento</label>
                <input class="form-input" type="text" placeholder="Ex: Rock in Rio" @bind="request.Nome" />
            </div>
            <div class="form-field">
                <label class="form-label">Capacidade Total</label>
                <input class="form-input" type="number" placeholder="Ex: 5000" @bind="request.CapacidadeTotal" />
            </div>
            <div class="form-field">
                <label class="form-label">Data do Evento</label>
                <input class="form-input" type="datetime-local" @bind="request.DataEvento" />
            </div>
            <div class="form-field">
                <label class="form-label">Preço Padrão (R$)</label>
                <input class="form-input" type="number" step="0.01" placeholder="Ex: 250,00" @bind="request.PrecoPadrao" />
            </div>
            <div class="form-field">
                <label class="form-label">URL da Imagem (opcional)</label>
                <input class="form-input" type="text" placeholder="https://... cole o link de uma imagem" @bind="request.ImagemUrl" />
            </div>

            <button class="btn btn-primary btn-full" @onclick="Cadastrar" disabled="@carregando">
                @(carregando ? "Cadastrando..." : "📅 Cadastrar Evento")
            </button>

            @if (!string.IsNullOrEmpty(erro)) { <div class="alert alert-error">⚠️ @erro</div> }
            @if (!string.IsNullOrEmpty(sucesso)) { <div class="alert alert-success">✅ @sucesso</div> }
        </div>
    </div>
}

@code {
    private CriarEventoRequest request = new();
    private string? erro;
    private string? sucesso;
    private bool carregando;

    protected override void OnInitialized() { if (!AuthService.EhAdmin) Navigation.NavigateTo("/"); }

    private async Task Cadastrar()
    {
        erro = sucesso = null;
        carregando = true;
        var (ok, mensagem) = await EventoService.Cadastrar(request);
        carregando = false;
        if (ok) { sucesso = mensagem; request = new(); }
        else erro = mensagem;
    }
}
