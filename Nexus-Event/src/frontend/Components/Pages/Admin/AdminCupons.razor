@page "/admin/cupons"
@using frontend.Models
@using frontend.Services
@inject CupomService CupomService
@inject AuthService AuthService
@inject NavigationManager Navigation

@if (!AuthService.EhAdmin)
{
    <div class="access-denied">⛔ Acesso negado</div>
}
else
{
    <div class="page-bg">
        <section class="page-header">
            <h1>🏷️ Cadastrar Cupom</h1>
            <p>Crie cupons de desconto para eventos</p>
        </section>

        <div class="admin-card" style="margin-top:-1rem;">
            <div class="form-field">
                <label class="form-label">Código</label>
                <input class="form-input" type="text" placeholder="Ex: DESC10" @bind="request.Codigo" />
            </div>
            <div class="form-field">
                <label class="form-label">Porcentagem de Desconto (%)</label>
                <input class="form-input" type="number" step="0.01" placeholder="Ex: 10" @bind="request.PorcentagemDesconto" />
            </div>
            <div class="form-field">
                <label class="form-label">Valor Mínimo (R$)</label>
                <input class="form-input" type="number" step="0.01" placeholder="Ex: 100" @bind="request.ValorMinimoRegra" />
            </div>
            <div class="form-field">
                <label class="form-label">Limite de Uso por Usuário</label>
                <input class="form-input" type="number" placeholder="Ex: 2" @bind="request.LimiteUsoPorUsuario" />
            </div>

            <button class="btn btn-primary btn-full" @onclick="Cadastrar" disabled="@carregando">
                @(carregando ? "Cadastrando..." : "🏷️ Cadastrar Cupom")
            </button>

            @if (!string.IsNullOrEmpty(erro)) { <div class="alert alert-error">⚠️ @erro</div> }
            @if (!string.IsNullOrEmpty(sucesso)) { <div class="alert alert-success">✅ @sucesso</div> }
        </div>
    </div>
}

@code {
    private CriarCupomRequest request = new() { Disponibilidade = true };
    private string? erro;
    private string? sucesso;
    private bool carregando;

    protected override void OnInitialized() { if (!AuthService.EhAdmin) Navigation.NavigateTo("/"); }

    private async Task Cadastrar()
    {
        erro = sucesso = null;
        carregando = true;
        var (ok, mensagem) = await CupomService.Cadastrar(request);
        carregando = false;
        if (ok) { sucesso = mensagem; request = new() { Disponibilidade = true }; }
        else erro = mensagem;
    }
}
