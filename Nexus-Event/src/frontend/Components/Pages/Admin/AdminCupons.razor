@page "/admin/cupons"
@using frontend.Models
@using frontend.Services
@inject CupomService CupomService
@inject AuthService AuthService
@inject NavigationManager Navigation

@if (!AuthService.EhAdmin)
{
    <p>Acesso negado.</p>
}
else
{
    <div class="form-container" style="max-width:500px; margin:2rem auto; padding:2rem;">
        <h1 style="color:#5f0d51; text-align:center;">Cadastrar Cupom</h1>

        <div class="form-group">
            <label>Código</label>
            <input class="form-control-custom" type="text"
                   placeholder="Ex: DESCONTO10"
                   @bind="request.Codigo" />
        </div>
        <div class="form-group">
            <label>Porcentagem de Desconto</label>
            <input class="form-control-custom" type="number"
                   step="0.01"
                   placeholder="Ex: 10"
                   @bind="request.PorcentagemDesconto" />
        </div>
        <div class="form-group">
            <label>Valor Mínimo</label>
            <input class="form-control-custom" type="number"
                   step="0.01"
                   placeholder="Ex: 100"
                   @bind="request.ValorMinimoRegra" />
        </div>
        <div class="form-group">
            <label>Limite de Uso por Usuário</label>
            <input class="form-control-custom" type="number"
                   placeholder="Ex: 2"
                   @bind="request.LimiteUsoPorUsuario" />
        </div>

        <button type="button" class="auth-main-button"
                @onclick="Cadastrar" disabled="@carregando">
            @(carregando ? "Cadastrando..." : "Cadastrar Cupom")
        </button>

        @if (!string.IsNullOrEmpty(erro))
        {
            <div style="background:#fee2e2;border:1px solid #ef4444;border-radius:8px;padding:12px;margin-top:1rem;color:#b91c1c;">
                ⚠️ @erro
            </div>
        }
        @if (!string.IsNullOrEmpty(sucesso))
        {
            <div style="background:#dcfce7;border:1px solid #22c55e;border-radius:8px;padding:12px;margin-top:1rem;color:#15803d;">
                ✅ @sucesso
            </div>
        }
    </div>
}

@code {
    private CriarCupomRequest request = new() { Disponibilidade = true };
    private string? erro;
    private string? sucesso;
    private bool carregando = false;

    protected override void OnInitialized()
    {
        if (!AuthService.EhAdmin)
            Navigation.NavigateTo("/");
    }

    private async Task Cadastrar()
    {
        erro = null;
        sucesso = null;
        carregando = true;

        var (ok, mensagem) = await CupomService.Cadastrar(request);
        carregando = false;

        if (ok)
        {
            sucesso = mensagem;
            request = new() { Disponibilidade = true };
        }
        else
        {
            erro = mensagem;
        }
    }
}