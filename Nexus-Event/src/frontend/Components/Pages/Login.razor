@page "/login"
@using frontend.Models
@using frontend.Services
@inject UsuarioService UsuarioService
@inject AuthService AuthService
@inject NavigationManager Navigation

<div class="auth-page">
    <div class="auth-card">
        <h1>Entrar</h1>
        <p class="auth-subtitle">Acesse sua conta para acompanhar eventos e ingressos.</p>

        <div class="form-group">
            <label>E-mail</label>
            <input class="form-control-custom" type="email"
                   placeholder="Digite seu e-mail"
                   @bind="request.Email" />
        </div>
        <div class="form-group">
            <label>Senha</label>
            <input class="form-control-custom" type="password"
                   placeholder="Digite sua senha"
                   @bind="request.Senha" />
        </div>

        <button type="button" class="auth-main-button"
                @onclick="Entrar" disabled="@carregando">
            @(carregando ? "Entrando..." : "Entrar")
        </button>

        @if (!string.IsNullOrEmpty(erro))
        {
            <div style="background:#fee2e2;border:1px solid #ef4444;border-radius:8px;padding:12px;margin-top:1rem;color:#b91c1c;">
                ⚠️ @erro
            </div>
        }

        <div class="auth-footer">
            <span>Ainda não tem conta?</span>
            <NavLink class="link-button" href="/register">Cadastre-se</NavLink>
        </div>
    </div>
</div>

@code {
    private LoginRequest request = new();
    private string? erro;
    private bool carregando = false;

    private async Task Entrar()
    {
        erro = null;
        carregando = true;

        if (string.IsNullOrWhiteSpace(request.Email) ||
            string.IsNullOrWhiteSpace(request.Senha))
        {
            erro = "Preencha todos os campos.";
            carregando = false;
            return;
        }

        var (ok, mensagem, usuario) = await UsuarioService.Login(request);
        carregando = false;

        if (ok && usuario is not null)
        {
            AuthService.Logar(usuario);
            Navigation.NavigateTo("/");
        }
        else
        {
            erro = mensagem;
        }
    }
}