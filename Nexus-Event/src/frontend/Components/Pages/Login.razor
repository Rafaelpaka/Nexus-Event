@page "/login"
@using frontend.Models
@using frontend.Services
@inject UsuarioService UsuarioService
@inject AuthService AuthService
@inject NavigationManager Navigation

<div class="form-page">
    <div class="form-card">
        <h1>🔐 Entrar</h1>
        <p class="form-card-subtitle">Acesse sua conta para comprar ingressos</p>

        <div class="form-field">
            <label class="form-label">E-mail</label>
            <input class="form-input" type="email" placeholder="seu@email.com" @bind="request.Email" />
        </div>
        <div class="form-field">
            <label class="form-label">Senha</label>
            <input class="form-input" type="password" placeholder="Sua senha" @bind="request.Senha" />
        </div>

        <button class="btn btn-primary btn-full" @onclick="Entrar" disabled="@carregando">
            @(carregando ? "Entrando..." : "Entrar")
        </button>

        @if (!string.IsNullOrEmpty(erro))
        {
            <div class="alert alert-error">⚠️ @erro</div>
        }

        <div style="text-align:center; margin-top:1.5rem; color:#6b7280;">
            Ainda não tem conta?
            <a href="/register" style="color:#a41bb6; font-weight:700; text-decoration:none;">Cadastre-se</a>
        </div>
    </div>
</div>

@code {
    private LoginRequest request = new();
    private string? erro;
    private bool carregando;

    private async Task Entrar()
    {
        erro = null;
        if (string.IsNullOrWhiteSpace(request.Email) || string.IsNullOrWhiteSpace(request.Senha))
        { erro = "Preencha todos os campos."; return; }

        carregando = true;
        var (ok, mensagem, usuario) = await UsuarioService.Login(request);
        carregando = false;

        if (ok && usuario is not null) { AuthService.Logar(usuario); Navigation.NavigateTo("/"); }
        else erro = mensagem;
    }
}
