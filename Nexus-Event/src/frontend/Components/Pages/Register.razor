@page "/register"
@using frontend.Models
@using frontend.Services
@inject UsuarioService UsuarioService
@inject NavigationManager Navigation

<div class="form-page">
    <div class="form-card">
        <h1>✨ Cadastro</h1>
        <p class="form-card-subtitle">Crie sua conta para comprar ingressos</p>

        <div class="form-field">
            <label class="form-label">Nome *</label>
            <input class="form-input" type="text" placeholder="Seu nome completo" @bind="request.Nome" />
        </div>
        <div class="form-field">
            <label class="form-label">CPF *</label>
            <input class="form-input" type="text" placeholder="000.000.000-00" @bind="request.Cpf" />
        </div>
        <div class="form-field">
            <label class="form-label">E-mail *</label>
            <input class="form-input" type="email" placeholder="seu@email.com" @bind="request.Email" />
        </div>
        <div class="form-field">
            <label class="form-label">Login *</label>
            <input class="form-input" type="text" placeholder="Seu nome de usuário" @bind="request.Login" />
        </div>
        <div class="form-field">
            <label class="form-label">Senha *</label>
            <input class="form-input" type="password" placeholder="Mín. 8 caracteres, maiúscula, número, especial" @bind="request.Senha" />
        </div>

        <button class="btn btn-primary btn-full" @onclick="Cadastrar" disabled="@carregando">
            @(carregando ? "Cadastrando..." : "Criar Conta")
        </button>

        @if (!string.IsNullOrEmpty(erro))
        {
            <div class="alert alert-error">⚠️ @erro</div>
        }
        @if (!string.IsNullOrEmpty(sucesso))
        {
            <div class="alert alert-success">✅ @sucesso<br/><small>Redirecionando em @contador segundos...</small></div>
        }

        <div style="text-align:center; margin-top:1.5rem; color:#6b7280;">
            Já tem conta?
            <a href="/login" style="color:#a41bb6; font-weight:700; text-decoration:none;">Entrar</a>
        </div>
    </div>
</div>

@code {
    private CriarUsuarioRequest request = new();
    private string? erro;
    private string? sucesso;
    private bool carregando;
    private int contador = 3;

    private async Task Cadastrar()
    {
        erro = sucesso = null;
        if (string.IsNullOrWhiteSpace(request.Nome) || string.IsNullOrWhiteSpace(request.Cpf) ||
            string.IsNullOrWhiteSpace(request.Email) || string.IsNullOrWhiteSpace(request.Senha))
        { erro = "Preencha todos os campos obrigatórios."; return; }

        carregando = true;
        var (ok, mensagem) = await UsuarioService.Cadastrar(request);
        carregando = false;

        if (ok)
        {
            sucesso = "Conta criada com sucesso!";
            request = new();
            for (int i = 3; i > 0; i--) { contador = i; StateHasChanged(); await Task.Delay(1000); }
            Navigation.NavigateTo("/login");
        }
        else erro = mensagem;
    }
}
