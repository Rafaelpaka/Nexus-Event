@page "/eventos"
@using frontend.Models
@using frontend.Services
@inject EventoService EventoService
@inject AuthService AuthService
@inject NavigationManager Navigation

<div class="page-bg">
    <section class="page-header">
        <h1>🎪 Explorar Eventos</h1>
        <p>Encontre sua próxima experiência inesquecível</p>
    </section>

    <div class="card-grid">
        @if (eventos is null)
        {
            <div class="loading">Carregando eventos...</div>
        }
        else if (!eventos.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon">📭</div>
                <h3>Nenhum evento disponível</h3>
                <p>Volte em breve para conferir novos eventos!</p>
            </div>
        }
        else
        {
            @foreach (var item in eventos)
            {
                <div class="card">
                    <div class="card-date">📅 @item.DataEvento.ToString("dd/MM/yyyy")</div>
                    <h3 class="card-title">@item.Nome</h3>
                    <div class="card-footer">
                        <span class="card-price">@item.PrecoPadrao.ToString("C")</span>
                        <button class="btn btn-gold" @onclick="() => ComprarIngresso(item.Id)">
                            🎫 Ver Ingressos
                        </button>
                    </div>
                </div>
            }
        }
    </div>
</div>

@code {
    private List<EventoModel>? eventos;

    protected override async Task OnInitializedAsync()
    {
        eventos = await EventoService.ListarTodos();
    }

    private void ComprarIngresso(int eventoId)
    {
        if (!AuthService.EstaLogado) { Navigation.NavigateTo("/login"); return; }
        Navigation.NavigateTo($"/comprar/{eventoId}");
    }
}
