@page "/eventos"
@using frontend.Models
@using frontend.Services
@inject EventoService EventoService
@inject AuthService AuthService
@inject NavigationManager Navigation

<div class="events-page-container">
    <section class="events-header-nexus">
        <h1>Explorar Eventos</h1>
        <p>Encontre a sua próxima experiência inesquecível na Nexus.</p>
    </section>

    <div class="events-grid-nexus">
        @if (eventos is null)
        {
            <p style="text-align:center">Carregando eventos...</p>
        }
        else if (!eventos.Any())
        {
            <p style="text-align:center">Não há eventos disponíveis no momento.</p>
        }
        else
        {
            @foreach (var item in eventos)
            {
                <div class="event-card-nexus">
                    <div class="event-body-nexus">
                        <p class="event-date">
                            @item.DataEvento.ToString("dd/MM/yyyy")
                        </p>
                        <h3>@item.Nome</h3>
                        <div class="event-footer-nexus">
                            <span class="event-price">
                                @item.PrecoPadrao.ToString("C")
                            </span>
                            <button class="btn-nexus-card"
                                @onclick="() => ComprarIngresso(item.Id)">
                                Ver Ingressos
                            </button>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

@code {
    private List<EventoModel>? eventos;

    protected override async Task OnInitializedAsync()
    {
        eventos = await EventoService.ListarTodos();
    }

    private void ComprarIngresso(int eventoId)
    {
        if (!AuthService.EstaLogado)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        Navigation.NavigateTo($"/comprar/{eventoId}");
    }
}