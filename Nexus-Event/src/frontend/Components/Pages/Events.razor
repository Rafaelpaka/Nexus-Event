@page "/eventos"
@rendermode InteractiveServer

<div class="events-page-container">
    <section class="events-header-nexus">
        <h1>Explorar Eventos</h1>
        <p>Encontre a sua próxima experiência inesquecível na Nexus.</p>
    </section>

    <div class="events-grid-nexus">
        @if (eventos == null)
        {
            <div class="loading-state">
                <p>Carregando eventos...</p>
            </div>
        }
        else if (!eventos.Any())
        {
            <div class="empty-state">
                <p>Não há eventos disponíveis de momento.</p>
            </div>
        }
        else
        {
            @foreach (var item in eventos)
            {
                <div class="event-card-nexus">
                    <div class="event-image-wrapper">
                        <img src="@item.ImagemUrl" class="event-thumb" alt="@item.Titulo" />
                        <span class="event-category-badge">@item.Categoria</span>
                    </div>
                    
                    <div class="event-body-nexus">
                        <p class="event-date">@item.Data.ToString("dd/MM/yyyy")</p>
                        <h3>@item.Titulo</h3>
                        <p class="event-location">@item.Local</p>
                        
                        <div class="event-footer-nexus">
                            <span class="event-price">@item.Preco.ToString("C")</span>
                            <button class="btn-nexus-card">Ver Ingressos</button>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

