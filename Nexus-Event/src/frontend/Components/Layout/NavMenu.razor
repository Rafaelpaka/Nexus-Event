@using frontend.Services
@inject AuthService AuthService
@inject NavigationManager Navigation
@implements IDisposable

<nav style="
    background: linear-gradient(90deg, #5f0d51, #a41bb6);
    padding: 1rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;">

    <a href="/" style="color:white; font-weight:800; font-size:1.2rem; text-decoration:none;">
        🎟️ NexusEvent
    </a>

    <div style="display:flex; gap:1rem; align-items:center;">
        <NavLink href="/eventos" style="color:white; text-decoration:none;">
            Eventos
        </NavLink>

        @if (AuthService.EstaLogado)
        {
            <NavLink href="/minhas-reservas" style="color:white; text-decoration:none;">
                Minhas Reservas
            </NavLink>

            @if (AuthService.EhAdmin)
            {
                <NavLink href="/admin/eventos" style="color:#ffd54a; text-decoration:none; font-weight:700;">
                    ⚙️ Admin Eventos
                </NavLink>
                <NavLink href="/admin/cupons" style="color:#ffd54a; text-decoration:none; font-weight:700;">
                    ⚙️ Admin Cupons
                </NavLink>
            }

            <span style="color:#d1d5db;">Olá, @AuthService.UsuarioAtual!.Nome</span>

            <button @onclick="Sair" style="
                background:transparent;
                border:1px solid white;
                color:white;
                border-radius:8px;
                padding:6px 14px;
                cursor:pointer;">
                Sair
            </button>
        }
        else
        {
            <NavLink href="/login" style="color:white; text-decoration:none;">
                Entrar
            </NavLink>
            <NavLink href="/register" style="
                background:#ffd54a;
                color:#5f0d51;
                padding:6px 14px;
                border-radius:8px;
                text-decoration:none;
                font-weight:700;">
                Cadastrar
            </NavLink>
        }
    </div>
</nav>

@code {
    protected override void OnInitialized()
    {
        AuthService.OnChange += StateHasChanged;
    }

    private void Sair()
    {
        AuthService.Deslogar();
        Navigation.NavigateTo("/");
    }

    public void Dispose()
    {
        AuthService.OnChange -= StateHasChanged;
    }
}