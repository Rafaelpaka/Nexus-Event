@page "/auth"
@inject NavigationManager Navigation

<PageTitle>Autenticação</PageTitle>

<div class="auth-container">
    <h1>Bem-vindo ao Nexus Event</h1>
    <p>Escolha como deseja continuar:</p>

    <div class="auth-buttons">
        <button class="main-button" @onclick="IrParaLogin">Entrar</button>
        <button class="secondary-button" @onclick="IrParaCadastro">Cadastrar-se</button>
    </div>
</div>

@code {
    private void IrParaLogin()
    {
        Navigation.NavigateTo("/login");
    }

    private void IrParaCadastro()
    {
        Navigation.NavigateTo("/register");
    }
}